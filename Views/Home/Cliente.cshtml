@model List<CloudAlertApp.Models.Cliente>

@{
    ViewData["Title"] = "Gestión de Clientes";
}

<style>
    :root {
        --bg-dark: #0f1419;
        --bg-secondary: #1a1f2e;
        --border-dark: #2d3748;
        --text-light: #e2e8f0;
        --text-muted: #a0aec0;
        --accent-blue: #60a5fa;
        --accent-green: #10b981;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-light);
    }

    .header-section {
        margin-bottom: 2rem;
    }

    .header-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-light);
    }

    .header-section p {
        color: var(--text-muted);
        font-size: 1rem;
    }

    .container-main {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 2rem;
        margin-top: 2rem;
    }

    .form-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 2rem;
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .form-title::before {
        content: "👤";
        font-size: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 0.75rem;
        background: var(--bg-dark);
        border: 1px solid var(--border-dark);
        border-radius: 6px;
        color: var(--text-light);
        font-size: 1rem;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    }

    .form-group input::placeholder {
        color: var(--text-muted);
    }

    .btn-guardar {
        width: 100%;
        padding: 0.85rem;
        background: var(--accent-blue);
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    .btn-guardar:hover {
        background: #3b82f6;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(96, 165, 250, 0.4);
    }

    .table-section {
        background: var(--bg-secondary);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 2rem;
    }

    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .filters {
        display: flex;
        gap: 0.75rem;
    }

    .filter-btn {
        padding: 0.5rem 1rem;
        background: transparent;
        border: 1px solid var(--border-dark);
        border-radius: 6px;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .filter-btn:hover,
    .filter-btn.active {
        background: var(--accent-blue);
        border-color: var(--accent-blue);
        color: white;
    }

    .btn-exportar {
        padding: 0.5rem 1.25rem;
        background: var(--accent-green);
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-exportar:hover {
        background: #059669;
        transform: translateY(-2px);
    }

    .btn-importar {
        padding: 0.5rem 1.25rem;
        background: #2563eb;
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-left: 0.5rem;
    }

    .btn-importar:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
    }

    .table-responsive {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

    thead {
        background: linear-gradient(135deg, var(--bg-dark) 0%, var(--border-dark) 100%);
    }

    th {
        padding: 1.25rem 1rem;
        text-align: left;
        font-weight: 700;
        color: var(--accent-blue);
        text-transform: uppercase;
        font-size: 0.80rem;
        letter-spacing: 0.8px;
        border-bottom: 2px solid var(--accent-blue);
    }

    td {
        padding: 1rem;
        border-bottom: 1px solid var(--border-dark);
        color: var(--text-light);
    }

    tbody tr {
        transition: background 0.3s ease;
    }

    tbody tr:hover {
        background: rgba(96, 165, 250, 0.05);
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .status-aws { background: #ff9900; color: white; }
    .status-azure { background: #0078d4; color: white; }
    .status-m365 { background: #00a4ef; color: white; }

    .btn-edit {
        background: var(--accent-blue);
        border: none;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .btn-edit:hover {
        background: #3b82f6;
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(96, 165, 250, 0.3);
    }

    .btn-edit.btn-icon {
        padding: 0.4rem 0.6rem;
        font-size: 1rem;
        line-height: 1;
        min-width: unset;
    }

    .footer-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-dark);
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    @@media (max-width: 1024px) {
        .container-main {
            grid-template-columns: 1fr;
        }
    }

    .alert {
        padding: 1rem;
        border-radius: 6px;
        margin-bottom: 1rem;
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid var(--accent-green);
        color: var(--accent-green);
    }

    .icon-status {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
    }

    .icon-status.active {
        background: var(--accent-green);
    }

    /* Modal Styles */
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .modal.active {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: var(--bg-secondary);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 2rem;
        width: 90%;
        max-width: 500px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from {
            transform: translateY(-50px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-dark);
        padding-bottom: 1rem;
    }

    .modal-header h2 {
        margin: 0;
        color: var(--text-light);
        font-size: 1.5rem;
    }

    .modal-close {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 2rem;
        cursor: pointer;
        transition: color 0.3s ease;
    }

    .modal-close:hover {
        color: var(--text-light);
    }

    .modal-footer {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        justify-content: flex-end;
    }

    .btn-cancelar {
        padding: 0.75rem 1.5rem;
        background: transparent;
        border: 1px solid var(--border-dark);
        border-radius: 6px;
        color: var(--text-light);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-cancelar:hover {
        background: var(--border-dark);
        border-color: var(--accent-blue);
    }

    .btn-actualizar {
        padding: 0.75rem 1.5rem;
        background: var(--accent-green);
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-actualizar:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
    }

    /* Estilos para checkboxes de servicios */
    .servicios-registro, .servicios-modal {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        margin-top: 0.75rem;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        background: var(--bg-dark);
        border: 1px solid var(--border-dark);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .checkbox-item:hover {
        border-color: var(--accent-blue);
        background: rgba(96, 165, 250, 0.05);
    }

    .checkbox-item input[type="checkbox"] {
        width: 1.1rem;
        height: 1.1rem;
        cursor: pointer;
        accent-color: var(--accent-blue);
        margin-right: 0.75rem;
    }

    .checkbox-item label {
        margin: 0;
        cursor: pointer;
        font-size: 0.95rem;
        color: var(--text-light);
        font-weight: 500;
    }

    .checkbox-item input[type="checkbox"]:checked + label {
        color: var(--accent-blue);
    }

    // css alert boton
    <>
.alert-bell {
    position: relative;
    cursor: pointer;
    font-size: 22px;
}

.badge {
    position: absolute;
    top: -5px;
    right: -10px;
    background: red;
    color: white;
    border-radius: 50%;
    padding: 3px 7px;
    font-size: 12px;
}

.alerts-panel {
    position: absolute;
    right: 0;
    top: 60px;
    width: 380px;
    max-height: 500px;
    overflow-y: auto;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0px 10px 30px rgba(0,0,0,0.3);
    padding: 0;
    z-index: 999;
}

.incident {
    padding: 8px;
    border-bottom: 1px solid #eee;
    cursor: pointer;
}

.critical {
    border-left: 5px solid red;
}

.high {
    border-left: 5px solid orange;
}

.critical-banner {
    background: red;
    color: white;
    padding: 10px;
    text-align: center;
}

.alert-header {
    padding: 15px;
    border-bottom: 1px solid #eee;
}

.alert-header h5 {
    margin: 0;
}

.provider-block {
    margin-top: 10px;
}

.provider-title {
    background: #ef4444;
    color: white;
    padding: 6px 10px;
    font-weight: bold;
    border-radius: 6px;
    display: flex;
    justify-content: space-between;
}

.badge-mini {
    background: #fff;
    color: #ef4444;
    border-radius: 20px;
    padding: 2px 8px;
    font-size: 11px;
    margin-left: 5px;
}

.incident-card {
    padding: 10px;
    border-bottom: 1px solid #eee;
    cursor: pointer;
}

.incident-card:hover {
    background: #f9fafb;
}

.tag {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: bold;
}

.tag-critical {
    background: #fee2e2;
    color: #b91c1c;
}

.tag-high {
    background: #ffedd5;
    color: #c2410c;
}

</style>


<div class="container-fluid py-5" style="background: var(--bg-dark);">
    <div class="container">
        <div class="header-section">
            <h1>Gestión de Clientes</h1>
            <p>Registro de cuentas y clasificación por tipo de servicio.</p>
        </div>

        <div id="criticalBanner" class="critical-banner d-none">
    ⚠️ Incidente crítico detectado
        </div>

        <div class="alert-bell" onclick="toggleAlerts()">
            🔔
            <span id="alertCount" class="badge">0</span>
        </div>

        <div id="alertsPanel" class="alerts-panel d-none">
            <h5>Incidentes Activos</h5>
            <div id="alertsContainer"></div>
        </div>

        <div id="alertSuccess" class="alert alert-success" style="display: none;">
            ✓ Cliente registrado exitosamente
        </div>

        <div class="container-main">
            <!-- Formulario Registro -->
            <div class="form-card">
                <div class="form-title">REGISTRAR CLIENTE</div>
                
                <form id="formCliente">
                    <div class="form-group">
                        <label>Nombre de la Empresa</label>
                        <input type="text" id="nombreEmpresa" placeholder="Ej: Global Tech" required>
                    </div>

                    <div class="form-group">
                        <label>Servicio Principal (IND-TI)</label>
                        <div class="servicios-registro">
                            <div class="checkbox-item">
                                <input type="checkbox" id="srv-aws" name="servicios" value="AWS">
                                <label for="srv-aws">Amazon Web Services (AWS)</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" id="srv-azure" name="servicios" value="Azure">
                                <label for="srv-azure">Microsoft Azure</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" id="srv-m365" name="servicios" value="M365">
                                <label for="srv-m365">Microsoft 365</label>
                            </div>
                        </div>
                        <small id="serviciosError" style="color: #ef4444; display: none; margin-top: 0.5rem; display: block;">Selecciona al menos un servicio</small>
                    </div>

                    <div class="form-group">
                        <label>Priorizar Cliente</label>
                        <div class="checkbox-item">
                            <input type="checkbox" id="prioritarioRegistro" name="priorizado">
                            <label for="prioritarioRegistro">Marcar como cliente prioritario ⭐</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Correo Administrador</label>
                        <input type="email" id="correoAdministrador" placeholder="admin@@gmail.com" pattern="^[^@@\s]+@@gmail\.com$" title="Solo se permite correo Gmail (@@gmail.com)" required>
                    </div>

                    <button type="submit" class="btn-guardar">Guardar Cliente</button>
                </form>
            </div>

            <!-- Tabla Clientes -->
            <div class="table-section">
                <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem;">
                    <button class="btn-exportar" id="btnExportar">📊 Exportar</button>
                    <button class="btn-importar" id="btnImportar">⬆ Importar Excel</button>
                    <input type="file" id="inputExcel" accept=".xlsx" style="display:none;" />
                    <button class="btn-exportar" id="btnLimpiar" style="background: #ef4444;">🗑️ Limpiar todo</button>
                </div>
                <div class="table-header">
                    <div class="filters">
                        <button class="filter-btn active" data-filter="todos">Todos</button>
                        <button class="filter-btn" data-filter="AWS">AWS</button>
                        <button class="filter-btn" data-filter="Azure">Azure</button>
                        <button class="filter-btn" data-filter="M365">M365</button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table id="tablaClientes">
                        <thead>
                            <tr>
                                <th>CLIENTE</th>
                                <th>SERVICIO</th>
                                <th>ADMINISTRADOR</th>
                                <th>FECHA REGISTRO</th>
                                <th>ACCIONES</th>
                            </tr>
                        </thead>
                        <tbody id="tablaClientesBody">
                        </tbody>
                    </table>
                </div>

                <div class="footer-info">
                    <span id="clientesCount">0 CLIENTES REGISTRADOS</span>
                    <span id="paginacion">1 DE 1</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar Cliente -->
<div id="modalEditar" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Editar Cliente</h2>
            <button class="modal-close" id="btnCerrarModal">&times;</button>
        </div>

        <form id="formEditar">
            <input type="hidden" id="clienteIdEdit">
            
            <div class="form-group">
                <label>Nombre de la Empresa</label>
                <input type="text" id="nombreEmpresaEdit" placeholder="Nombre de la empresa" required>
            </div>

            <div class="form-group">
                <label>Servicio Principal (IND-TI)</label>
                <div class="servicios-modal">
                    <div class="checkbox-item">
                        <input type="checkbox" id="srv-aws-edit" name="servicios" value="AWS">
                        <label for="srv-aws-edit">Amazon Web Services (AWS)</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="srv-azure-edit" name="servicios" value="Azure">
                        <label for="srv-azure-edit">Microsoft Azure</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="srv-m365-edit" name="servicios" value="M365">
                        <label for="srv-m365-edit">Microsoft 365</label>
                    </div>
                </div>
                <small id="serviciosErrorEdit" style="color: #ef4444; display: none; margin-top: 0.5rem; display: block;">Selecciona al menos un servicio</small>
            </div>

            <div class="form-group">
                <label>Priorizar Cliente</label>
                <div class="checkbox-item">
                    <input type="checkbox" id="prioritarioEdit" name="priorizado">
                    <label for="prioritarioEdit">Marcar como cliente prioritario ⭐</label>
                </div>
            </div>

            <div class="form-group">
                <label>Correo Administrador</label>
                <input type="email" id="correoAdministradorEdit" placeholder="admin@@gmail.com" pattern="^[^@@\s]+@@gmail\.com$" title="Solo se permite correo Gmail (@@gmail.com)" required>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cancelar" id="btnCancelarEdit">Cancelar</button>
                <button type="submit" class="btn-actualizar">Actualizar Cliente</button>
            </div>
        </form>
    </div>
</div>

<script>
    let clientesActuales = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model ?? new List<CloudAlertApp.Models.Cliente>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    let filtroActual = 'todos';
    let visible = false;

    function esCorreoGmail(correo) {
        return /^[^\x40\s]+\x40gmail\.com$/i.test(correo.trim());
    }

    function renderizarTabla() {
        const tbody = document.getElementById('tablaClientesBody');
        tbody.innerHTML = '';

        let clientesFiltrados = clientesActuales;
        if (filtroActual !== 'todos') {
            clientesFiltrados = clientesActuales.filter(c => {
                const servicios = c.servicios && c.servicios.length > 0 ? c.servicios : (c.servicioPrincipal ? [c.servicioPrincipal] : []);
                return servicios.includes(filtroActual);
            });
        }

        // Ordenar: priorizados primero
        clientesFiltrados = clientesFiltrados.sort((a, b) => {
            if (a.priorizado === b.priorizado) return 0;
            return a.priorizado ? -1 : 1;
        });

        clientesFiltrados.forEach(cliente => {
            const row = document.createElement('tr');
            const servicios = cliente.servicios && cliente.servicios.length > 0 ? cliente.servicios : (cliente.servicioPrincipal ? [cliente.servicioPrincipal] : []);
            const fecha = new Date(cliente.fechaRegistro).toLocaleDateString('es-ES', { year: 'numeric', month: '2-digit', day: '2-digit' });
            const estrella = cliente.priorizado ? '⭐ ' : '';
            
            const badgesHTML = servicios.map(srv => {
                const badgeClass = `status-${srv.toLowerCase()}`;
                return `<span class="status-badge ${badgeClass}">${srv}</span>`;
            }).join('');

            row.innerHTML = `
                <td>
                    <span class="icon-status active"></span> ${estrella}${cliente.nombreEmpresa}
                </td>
                <td>
                    ${badgesHTML}
                </td>
                <td>${cliente.correoAdministrador}</td>
                <td>${fecha}</td>
                <td>
                    <button class="btn-edit btn-icon" onclick="editarCliente(${cliente.id})" title="Editar">✎</button>
                    <button class="btn-edit btn-icon" onclick="eliminarCliente(${cliente.id})" title="Eliminar" style="background: #ef4444; margin-left: 0.4rem;">✕</button>
                </td>
            `;
            tbody.appendChild(row);
        });

        document.getElementById('clientesCount').textContent = `${clientesFiltrados.length} CLIENTES REGISTRADOS`;
    }

    async function eliminarCliente(id) {
        if (confirm('¿Estás seguro de que deseas eliminar este cliente?')) {
            const response = await fetch('/Home/EliminarCliente', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}`
            });

            if (response.ok) {
                clientesActuales = clientesActuales.filter(c => c.id !== id);
                renderizarTabla();
            }
        }
    }

    async function priorizarCliente(id) {
        const response = await fetch('/Home/PriorizarCliente', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}`
        });

        if (response.ok) {
            const clienteActualizado = await response.json();
            const index = clientesActuales.findIndex(c => c.id === clienteActualizado.id);
            if (index !== -1) {
                clientesActuales[index] = clienteActualizado;
            }
            renderizarTabla();
        }
    }

    function editarCliente(id) {
        const cliente = clientesActuales.find(c => c.id === id);
        if (!cliente) return;

        document.getElementById('clienteIdEdit').value = cliente.id;
        document.getElementById('nombreEmpresaEdit').value = cliente.nombreEmpresa;
        document.getElementById('correoAdministradorEdit').value = cliente.correoAdministrador;
        document.getElementById('prioritarioEdit').checked = cliente.priorizado || false;

        // Desmarcar todos los checkboxes
        document.querySelectorAll('.servicios-modal input[name=\"servicios\"]').forEach(cb => cb.checked = false);

        // Marcar los servicios del cliente
        const servicios = cliente.servicios && cliente.servicios.length > 0 
            ? cliente.servicios 
            : (cliente.servicioPrincipal ? [cliente.servicioPrincipal] : []);
        
        servicios.forEach(servicio => {
            const checkbox = document.querySelector(`.servicios-modal input[value="${servicio}"]`);
            if (checkbox) checkbox.checked = true;
        });

        // Limpiar mensaje de error
        document.getElementById('serviciosErrorEdit').style.display = 'none';

        document.getElementById('modalEditar').classList.add('active');
    }

    // Cerrar Modal
    document.getElementById('btnCerrarModal').addEventListener('click', () => {
        document.getElementById('modalEditar').classList.remove('active');
    });

    document.getElementById('btnCancelarEdit').addEventListener('click', () => {
        document.getElementById('modalEditar').classList.remove('active');
    });

    // Cerrar modal al hacer click fuera
    document.getElementById('modalEditar').addEventListener('click', (e) => {
        if (e.target.id === 'modalEditar') {
            document.getElementById('modalEditar').classList.remove('active');
        }
    });

    // Formulario Editar Submit
    document.getElementById('formEditar').addEventListener('submit', async (e) => {
        e.preventDefault();

        const id = document.getElementById('clienteIdEdit').value;
        const nombreEmpresa = document.getElementById('nombreEmpresaEdit').value;
        const servicios = Array.from(document.querySelectorAll('.servicios-modal input[name=\"servicios\"]:checked'))
            .map(cb => cb.value);
        const correoAdministrador = document.getElementById('correoAdministradorEdit').value;
        const priorizado = document.getElementById('prioritarioEdit').checked;

        // Validar que se seleccione al menos un servicio
        if (servicios.length === 0) {
            document.getElementById('serviciosErrorEdit').textContent = 'Selecciona al menos un servicio';
            document.getElementById('serviciosErrorEdit').style.display = 'block';
            return;
        }

        if (!esCorreoGmail(correoAdministrador)) {
            alert('El correo del administrador debe ser Gmail (gmail.com).');
            return;
        }

        const response = await fetch('/Home/ActualizarCliente', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}&nombreEmpresa=${encodeURIComponent(nombreEmpresa)}&servicios=${encodeURIComponent(servicios.join(','))}&correoAdministrador=${encodeURIComponent(correoAdministrador)}&priorizado=${priorizado}`
        });

        if (response.ok) {
            const clienteActualizado = await response.json();
            const index = clientesActuales.findIndex(c => c.id === clienteActualizado.id);
            if (index !== -1) {
                clientesActuales[index] = clienteActualizado;
            }
            filtroActual = 'todos';
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.filter-btn[data-filter="todos"]').classList.add('active');
            renderizarTabla();
            document.getElementById('modalEditar').classList.remove('active');
            
            // Mostrar alerta
            const alert = document.getElementById('alertSuccess');
            alert.textContent = '✓ Cliente actualizado exitosamente';
            alert.style.display = 'block';
            setTimeout(() => alert.style.display = 'none', 3000);
        }
    });

    // Formulario Submit
    document.getElementById('formCliente').addEventListener('submit', async (e) => {
        e.preventDefault();

        const nombreEmpresa = document.getElementById('nombreEmpresa').value;
        const servicios = Array.from(document.querySelectorAll('.servicios-registro input[name=\"servicios\"]:checked'))
            .map(cb => cb.value);
        const correoAdministrador = document.getElementById('correoAdministrador').value;
        const priorizado = document.getElementById('prioritarioRegistro').checked;

        // Validar que se seleccione al menos un servicio
        if (servicios.length === 0) {
            document.getElementById('serviciosError').textContent = 'Selecciona al menos un servicio';
            document.getElementById('serviciosError').style.display = 'block';
            return;
        }

        if (!esCorreoGmail(correoAdministrador)) {
            alert('El correo del administrador debe ser Gmail (gmail.com).');
            return;
        }

        const response = await fetch('/Home/GuardarCliente', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `nombreEmpresa=${encodeURIComponent(nombreEmpresa)}&servicios=${encodeURIComponent(servicios.join(','))}&correoAdministrador=${encodeURIComponent(correoAdministrador)}&priorizado=${priorizado}`
        });

        if (response.ok) {
            const nuevoCliente = await response.json();
            clientesActuales.push(nuevoCliente);
            filtroActual = 'todos';
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.filter-btn[data-filter="todos"]').classList.add('active');
            renderizarTabla();
            document.getElementById('formCliente').reset();
            
            // Mostrar alerta
            const alert = document.getElementById('alertSuccess');
            alert.style.display = 'block';
            setTimeout(() => alert.style.display = 'none', 3000);
        }
    });

    // Filtros
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            e.target.classList.add('active');
            filtroActual = e.target.dataset.filter;
            renderizarTabla();
        });
    });

    // Exportar
    document.getElementById('btnExportar').addEventListener('click', () => {
        window.location.href = '/Home/ExportarExcel';
    });

    // Importar
    document.getElementById('btnImportar').addEventListener('click', () => {
        document.getElementById('inputExcel').click();
    });

    document.getElementById('inputExcel').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) {
            return;
        }

        const formData = new FormData();
        formData.append('archivoExcel', file);

        const response = await fetch('/Home/ImportarExcel', {
            method: 'POST',
            body: formData
        });

        if (!response.ok) {
            const errorMessage = await response.text();
            alert(`No se pudo importar el Excel: ${errorMessage}`);
            e.target.value = '';
            return;
        }

        const resultado = await response.json();
        alert(`Importación completada. Importados: ${resultado.importados}, Omitidos: ${resultado.omitidos}`);
        window.location.reload();
        e.target.value = '';
    });

    // Limpiar todo
    document.getElementById('btnLimpiar').addEventListener('click', async () => {
        if (confirm('⚠️ Esto eliminará todos los clientes. ¿Continuar?')) {
            const response = await fetch('/Home/LimpiarTodos', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
            });

            if (response.ok) {
                clientesActuales = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model ?? new List<CloudAlertApp.Models.Cliente>(), new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
                renderizarTabla();
                alert('✓ Datos limpiados exitosamente');
            }
        }
    });

    // Inicializar
    // Limpiar mensaje de error cuando se selecciona un checkbox en el formulario de registro
    document.querySelectorAll('.servicios-registro input[name="servicios"]').forEach(checkbox => {
        checkbox.addEventListener('change', () => {
            const serviciosSeleccionados = document.querySelectorAll('.servicios-registro input[name="servicios"]:checked').length;
            if (serviciosSeleccionados > 0) {
                document.getElementById('serviciosError').style.display = 'none';
            }
        });
    });

    // Limpiar mensaje de error cuando se selecciona un checkbox en el modal de edición
    document.querySelectorAll('.servicios-modal input[name="servicios"]').forEach(checkbox => {
        checkbox.addEventListener('change', () => {
            const serviciosSeleccionados = document.querySelectorAll('.servicios-modal input[name="servicios"]:checked').length;
            if (serviciosSeleccionados > 0) {
                document.getElementById('serviciosErrorEdit').style.display = 'none';
            }
        });
    });


    //alert button
    function toggleAlerts() {
    const panel = document.getElementById("alertsPanel");
    visible = !visible;

    panel.classList.toggle("d-none");

    if (visible) loadAlerts();
    }

async function loadAlerts() {
    const res = await fetch("/api/incidentes/activos");
    const data = await res.json();

    const container = document.getElementById("alertsContainer");
    container.innerHTML = "";

    let total = 0;

    data.forEach(group => {
        total += group.total;

        let html = `
            <div class="provider-block">

                <div class="provider-title">
                    ${group.proveedor} (${group.total})
                    <div>
                        <span class="badge-mini">${group.criticos} Crítico</span>
                        <span class="badge-mini">${group.altos} Alto</span>
                    </div>
                </div>
        `;

        group.incidentes.forEach(i => {

            let tag = "";
            if (i.severidad === 1)
                tag = `<span class="tag tag-critical">Crítica</span>`;
            else if (i.severidad === 2)
                tag = `<span class="tag tag-high">Alta</span>`;

            html += `
                <div class="incident-card" onclick="openDetail('${i.urlDetalle}')">
                    ${tag}
                    <div><strong>${i.titulo}</strong></div>
                    <small>${new Date(i.fecha).toLocaleString()}</small>
                </div>
            `;
        });

        html += `</div>`;

        container.innerHTML += html;
    });

    document.getElementById("alertCount").innerText = total;

    checkCritical(data);
}

function openDetail(url) {
    window.open(url, "_blank"); // ✔️ cumple criterio
}

function checkCritical(data) {
    const banner = document.getElementById("criticalBanner");

    const hasCritical = data.some(x => x.criticos > 0);

    if (hasCritical) {
        banner.classList.remove("d-none");
    }
}

    renderizarTabla();
</script>
