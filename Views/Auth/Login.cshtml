@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesion";
}

<div class="container auth-page py-5">
    <div class="row justify-content-center align-items-center">
        <div class="col-lg-5 col-md-8">
            <div class="card auth-card shadow-lg border-0">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h2 fw-bold text-center mb-2">Iniciar sesion</h1>
                    <p class="text-center text-muted mb-4">Accede a tu panel de monitoreo y alertas.</p>

                    @if (TempData["AuthMessage"] is string authMessage)
                    {
                        <div class="alert alert-info" role="alert">@authMessage</div>
                    }

                    <form asp-action="Login" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="correo@empresa.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" placeholder="Tu contrasena segura" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-info w-100 fw-bold text-white">Entrar</button>
                    </form>

                    <p class="text-center mt-4 mb-0">
                        No tienes cuenta?
                        <a asp-controller="Auth" asp-action="Register" class="fw-bold">Registrate aqui</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
